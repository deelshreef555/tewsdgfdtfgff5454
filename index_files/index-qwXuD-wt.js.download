        .tiktok {
          width: 48px;
          height: 48px;
        }
  
        .loading {
          display: flex;
          width: 200px;
          height: 200px;
          align-items: center;
          transform: scale(0.24);
          transform-origin: 0 0;
        }
  
        .loading-black {
          fill: #000 !important;
        }
  
        .loading-red {
          fill: #fe2c55;
          stroke-width: 0;
          r: 36px;
          cx: 120px;
          cy: 44px;
          animation: tiktok-red 1s cubic-bezier(0.05,0,1,1) infinite;
        }
  
        .loading-green {
          fill: #3af2ff;
          stroke-width: 0;
          r: 36px;
          cx: 40px;
          cy: 44px;
          animation: tiktok-green 1s cubic-bezier(0.05,0,1,1) infinite;
        }
  
        @keyframes tiktok-green {
          25% {
            cx: 80px;
            r: 43.2px;
          }
          50% {
            cx: 120px;
            r: 36px;
          }
          75% {
            cx: 80px;
            r: 21.6px;
          }
          to {
            cx: 40px;
            r: 36px;
          }
        }
  
        @keyframes tiktok-red {
          25% {
            cx: 80px;
            r: 24px;
          }
          50% {
            cx: 40px;
            r: 36px;
          }
          75% {
            cx: 80px;
            r: 43.2px;
          }
          to {
            cx: 120px;
            r: 36px;
          }
        }
      `})]}),yv=D.lazy(()=>In(()=>import("./page-BA1kmtvM.js"),__vite__mapDeps([0,1,2,3]),import.meta.url)),vv=D.lazy(()=>In(()=>import("./page-QLorBWLo.js"),__vite__mapDeps([4,1]),import.meta.url)),gv=D.lazy(()=>In(()=>import("./page-CnWxKiYT.js"),__vite__mapDeps([5,1,2]),import.meta.url)),Sv=D.lazy(()=>In(()=>import("./page-DgYrtdBg.js"),__vite__mapDeps([6,1,2,3]),import.meta.url)),pv=[{path:Du.HOME,component:Sv,exact:!0},{path:Du.CUSTOM,component:yv},{path:Du.ORDER_SUMMARY,component:vv},{path:Du.PAYMENT_SUCCESS,component:gv}],bv=()=>rt.jsx("div",{className:"flex justify-center items-center min-h-screen",children:rt.jsx(mv,{})}),Ev=()=>rt.jsx(D.Suspense,{fallback:rt.jsx(bv,{}),children:rt.jsxs(By,{children:[pv.map(({path:c,component:o})=>rt.jsx(zf,{path:c,element:rt.jsx(o,{})},c)),rt.jsx(zf,{path:"/old-path",element:rt.jsx(Hy,{to:Du.HOME,replace:!0})})]})}),Tv=()=>rt.jsx("div",{className:"App",children:rt.jsx("main",{children:rt.jsx(Ev,{})})});Q0.createRoot(document.getElementById("root")).render(rt.jsx(D.StrictMode,{children:rt.jsx(uv,{children:rt.jsx(Tv,{})})}));export{ih as L,Av as R,L0 as a,B0 as b,U0 as g,rt as j,D as r};
